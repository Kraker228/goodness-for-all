# CMS GitHub OAuth (Sveltia CMS op /admin).
# OAuth App: https://github.com/settings/developers
#   Callback URL: https://<jouw-vercel-domein>/api/cms/callback
GITHUB_CLIENT_ID=replace-with-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-oauth-client-secret
CMS_ALLOWED_DOMAINS=<jouw-vercel-domein>

CONTACT_TO=info@goodnessforall.nl
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=postmaster@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="Goodness for All <postmaster@example.com>"

# Buurthuis bestelformulier logging naar Google Sheets via Apps Script webhook.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/replace-with-deployment-id/exec
GOOGLE_SHEETS_WEBHOOK_SECRET=replace-with-random-secret

# Alternatief: directe Google Sheets API via service-account key.
GOOGLE_SHEETS_SPREADSHEET_ID=replace-with-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=Bestellingen
GOOGLE_SERVICE_ACCOUNT_EMAIL=goodness-orders@example-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"

# Fallback: GitHub CSV logging als Google Sheets niet is ingesteld.
# Gebruik in productie een fine-grained GitHub token met Contents: read/write.
ORDER_LOG_GITHUB_TOKEN=github_pat_replace_me
ORDER_LOG_GITHUB_REPO=sirprikkel/goodness-for-all
ORDER_LOG_GITHUB_BRANCH=master
ORDER_LOG_GITHUB_PATH=content/buurthuis-bestellingen.csv
